# All env vars are centralized in client/src/config/env.ts

VITE_API_URL=http://localhost:3000
VITE_USE_FILE_DATA=false

# Optional: skip animations (accessibility)
# VITE_SKIP_ANIMATIONS=true

# EmailJS (footer contact form + calculator lead notification)
# See docs/email-templates/ for HTML templates
VITE_EMAILJS_SERVICE_ID=your_service_id
VITE_EMAILJS_TEMPLATE_ID=your_template_id
VITE_EMAILJS_PUBLIC_KEY=your_public_key
# Optional: calculator lead admin notification (uses same service + public key)
VITE_EMAILJS_CALCULATOR_TEMPLATE_ID=calculator_lead_notification

# Home hero videos (Cloudinary — required on Netlify/production)
# Upload hero-vid-desktop.mov and hero-vid-mobile.mov to Media Library, then paste delivery URLs.
# Posters: first-frame JPEGs in client/public/assets/ (imported via src/assets/heroPosters.ts)
# VITE_HERO_VIDEO_DESKTOP_URL=https://res.cloudinary.com/<cloud>/video/upload/q_auto,f_auto/<public_id>
# VITE_HERO_VIDEO_MOBILE_URL=https://res.cloudinary.com/<cloud>/video/upload/q_auto,f_auto/<public_id>
